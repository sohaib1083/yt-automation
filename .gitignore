.env
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# Generated pipeline artifacts
scripts/*/
assets/*/
videos/*/

# YouTube OAuth credentials & secrets — never commit these
credentials/token.pickle
credentials/client_secrets.json
client_secret*.json

# Keep placeholder dirs
!scripts/.gitkeep
!assets/.gitkeep
!videos/.gitkeep
!credentials/.gitkeep
